# App
DEFAULT_DOMAIN=example.com
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local SQLite database used by `bun dev` and tests.
# Data can be synchronized from remote D1 with `bun run d1:sync-local`.
LOCAL_SQLITE_PATH=.tmp/flashinbox-local.sqlite

# Wrangler/OpenNext commands generate ignored .tmp/wrangler.*.toml from these values.
D1_DATABASE_NAME=flashinbox-db
D1_DATABASE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Secrets for local development.
# Use strong unique values outside local tests.
ADMIN_TOKEN=flashinbox-local-admin
KEY_PEPPER=replace-with-local-key-pepper
SESSION_SECRET=replace-with-local-session-secret

# Cloudflare Turnstile official testing keys.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Expiration and content limits
KEY_EXPIRE_DAYS=15
UNCLAIMED_EXPIRE_DAYS=7
SESSION_EXPIRE_HOURS=24
ADMIN_SESSION_EXPIRE_HOURS=4
MAX_BODY_TEXT=102400
MAX_BODY_HTML=512000

# Rate limits
RATE_LIMIT_CREATE=10/10m
RATE_LIMIT_CLAIM=3/30m
RATE_LIMIT_RECOVER=5/60m
RATE_LIMIT_RENEW=10/60m

# Outbound email
SEND_RATE_LIMIT_HOUR=20
SEND_RATE_LIMIT_DAY=100
SEND_MAX_RECIPIENTS=10
SEND_MAX_SUBJECT_CHARS=180
SEND_MAX_BODY_TEXT_CHARS=3000
SEND_MAX_ATTACHMENT_URLS=10
SEND_ALLOWED_IFRAME_DOMAINS=youtube.com,youtu.be,vimeo.com,bilibili.com,player.bilibili.com

# unrestricted / whitelist / blacklist
SEND_POLICY_MODE=unrestricted
SEND_RECIPIENT_WHITELIST=
SEND_RECIPIENT_BLACKLIST=

# Umami analytics
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=
UMAMI_ADMIN_WEBSITE_ID=
UMAMI_ALLOWED_ORIGINS=
NEXT_PUBLIC_UMAMI_ALLOWED_ORIGINS=
